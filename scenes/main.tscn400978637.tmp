[connection signal="pressed" from="UI/SettingsButton" to="UI" method="_toggle_settings_screen"]
[connection signal="button_down" from="UI/TutorialScreen/Control/Exit" to="UI" method="_close_tutorial_screen"]
[connection signal="button_down" from="UI/TutorialScreen/Control/Next" to="UI" method="_change_tutorial_page" binds= [1]]
[connection signal="button_down" from="UI/TutorialScreen/Control/Back" to="UI" method="_change_tutorial_page" binds= [-1]]
